<Window x:Class="PokerLogsViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:PokerLogsViewer.Models"
        Title="Poker Logs Viewer" Height="640" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Placeholder" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontStyle"  Value="Italic"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Top toolbar -->
        <DockPanel DockPanel.Dock="Top" Margin="8">
            <Button Content="Browse..." Command="{Binding BrowseCommand}"
                    Width="90" Margin="0,0,8,0"/>
            <Button Content="Start Scanning" Command="{Binding ScanCommand}"
                    Width="130" DockPanel.Dock="Right"/>
            <TextBox Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="True" VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Three-panel body -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*" MinWidth="140"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Tables -->
            <DockPanel Grid.Column="0">
                <TextBlock Text="Tables" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <Grid>
                    <ListBox ItemsSource="{Binding Tables}"
                             SelectedItem="{Binding SelectedTable}"
                             DisplayMemberPath="TableName"/>
                    <TextBlock Text="No data. Click 'Start Scanning'.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tables.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#EEE"/>

            <!-- MIDDLE: Hand IDs -->
            <DockPanel Grid.Column="2">
                <TextBlock Text="Hand IDs" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <Grid>
                    <ListBox ItemsSource="{Binding SelectedTable.Hands}"
                             SelectedItem="{Binding SelectedHand}"
                             DisplayMemberPath="HandID"/>
                    <TextBlock Text="Select a table">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTable}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#EEE"/>

            <!-- RIGHT: Details -->
            <DockPanel Grid.Column="4">
                <TextBlock Text="Details" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <Grid>
                    <ContentControl Content="{Binding SelectedHand}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type m:PokerHand}">
                                <Border Padding="8" BorderBrush="#DDD" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HandID, StringFormat='Hand ID: {0}'}"
                                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                                        <TextBlock Text="Players" FontWeight="Bold"/>
                                        <ItemsControl ItemsSource="{Binding Players}" Margin="8,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Winners" FontWeight="Bold"/>
                                        <ItemsControl ItemsSource="{Binding Winners}" Margin="8,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding WinAmount, StringFormat='Win Amount: {0}'}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <TextBlock Text="Select a hand to view details">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedHand}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
