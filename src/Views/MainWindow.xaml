<Window x:Class="PokerLogsViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PokerLogsViewer.Services"
        xmlns:conv="clr-namespace:PokerLogsViewer.Converters"
        xmlns:m="clr-namespace:PokerLogsViewer.Models"
        Title="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[Title], Mode=OneWay}" Height="640" Width="1100" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Placeholder" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontStyle"  Value="Italic"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <DockPanel.Resources>
            <conv:StatusKindToIconConverter x:Key="StatusIconConv" />
        </DockPanel.Resources>
        <!-- Top toolbar -->
        <DockPanel DockPanel.Dock="Top" Margin="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[ButtonBrowse], Mode=OneWay}" Command="{Binding BrowseCommand}"
                        Width="90" Margin="0,0,8,0"/>
                <Button Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[ButtonScan], Mode=OneWay}" Command="{Binding ScanCommand}"
                        Width="130" Margin="0,0,8,0"/>
                <TextBox Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" VerticalContentAlignment="Center" Width="420"/>
            </StackPanel>

            <!-- language switch -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="EN" Click="SetCultureEn" Width="40" Margin="0,0,8,0"/>
                <Button Content="RU" Click="SetCultureRu" Width="40"/>
            </StackPanel>
        </DockPanel>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <!-- Show icon + localized status; icon uses converter to pick glyph -->
                <!-- Include emoji/symbol fonts first so check glyphs render correctly -->
                <TextBlock FontWeight="SemiBold" FontFamily="Segoe UI Emoji, Segoe UI Symbol, Segoe UI">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusKind}" Value="Scanning">
                                    <Setter Property="Foreground" Value="#005FB8"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusKind}" Value="Done">
                                    <Setter Property="Foreground" Value="#107C10"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusKind}" Value="Error">
                                    <Setter Property="Foreground" Value="#C50F1F"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding StatusKind, Converter={StaticResource StatusIconConv}, Mode=OneWay}"/>
                    <Run Text=" " />
                    <Run Text="{Binding Status}" />
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Three-panel body -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*" MinWidth="140"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Tables -->
            <DockPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[TablesHeader]}" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <TextBox DockPanel.Dock="Top"
                         Margin="0,0,0,6"
                         Text="{Binding TableFilterText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[TableFilterToolTip], Mode=OneWay}"/>
                <Grid>
                    <ListBox ItemsSource="{Binding FilteredTables}"
                             SelectedItem="{Binding SelectedTable}"
                             DisplayMemberPath="TableName"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[NoDataPlaceholder], Mode=OneWay}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tables.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#EEE"/>

            <!-- MIDDLE: Hand IDs -->
            <DockPanel Grid.Column="2">
                <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[HandIdsHeader], Mode=OneWay}" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <TextBox DockPanel.Dock="Top"
                         Margin="0,0,0,6"
                         Text="{Binding HandFilterText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[HandFilterToolTip], Mode=OneWay}"/>
                <Grid>
                    <ListBox ItemsSource="{Binding FilteredHands}"
                             SelectedItem="{Binding SelectedHand}"
                             DisplayMemberPath="HandID"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[SelectTablePlaceholder], Mode=OneWay}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTable}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#EEE"/>

            <!-- RIGHT: Details -->
            <DockPanel Grid.Column="4">
                <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[DetailsHeader], Mode=OneWay}" Style="{StaticResource PanelHeader}" DockPanel.Dock="Top"/>
                <Grid>
                    <ContentControl Content="{Binding SelectedHand}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type m:PokerHand}">
                                <Border Padding="8" BorderBrush="#DDD" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HandID, StringFormat='Hand ID: {0}'}"
                                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                                        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[PlayersLabel], Mode=OneWay}" FontWeight="Bold"/>
                                        <ItemsControl ItemsSource="{Binding Players}" Margin="8,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[WinnersLabel], Mode=OneWay}" FontWeight="Bold"/>
                                        <ItemsControl ItemsSource="{Binding Winners}" Margin="8,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock>
                                            <Run Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[WinAmountLabel], Mode=OneWay}" FontWeight="Bold"/>
                                            <Run Text="{Binding WinAmount}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=[SelectHandPlaceholder], Mode=OneWay}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Placeholder}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedHand}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
